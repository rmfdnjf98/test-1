<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Georgia, "Times New Roman", serif;
            background: #f5f1ea;
            color: #2f2a24;
        }

        .wrap {
            max-width: 720px;
            margin: 56px auto;
            padding: 0 20px;
        }

        .card {
            background: #fffdf9;
            border: 1px solid #ded6ca;
            border-radius: 14px;
            padding: 28px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        h1 {
            margin: 0 0 8px;
            font-size: 30px;
        }

        .sub {
            margin: 0 0 24px;
            color: #6e655c;
            font-size: 15px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 700;
            font-size: 14px;
        }

        .field {
            margin-bottom: 18px;
        }

        input,
        textarea {
            width: 100%;
            border: 1px solid #cfc4b5;
            border-radius: 10px;
            padding: 12px 14px;
            font: inherit;
            background: #fff;
        }

        textarea {
            min-height: 180px;
            resize: vertical;
            line-height: 1.6;
        }

        input:focus,
        textarea:focus {
            outline: none;
            border-color: #8a6d4e;
            box-shadow: 0 0 0 3px rgba(138, 109, 78, 0.14);
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 24px;
        }

        .btn {
            display: inline-block;
            border: 0;
            border-radius: 10px;
            padding: 12px 18px;
            font: inherit;
            text-decoration: none;
            cursor: pointer;
        }

        .btn-primary {
            background: #3e3126;
            color: #fff;
        }

        .btn-secondary {
            background: #ece4d9;
            color: #3e3126;
        }
    </style>
</head>
<body>
<div class="wrap">
    <div class="card">
        <h1></h1>

        <form action="/guestbook/write" method="post">
            <div class="field">
                <label for="author">이름</label>
                <input id="author" name="author" type="text" placeholder="이름" required>
            </div>

            <div class="field">
                <label for="content">내용</label>
                <textarea id="content" name="content" placeholder="내용" required></textarea>
            </div>

            <div class="actions">
                <button class="btn btn-primary" type="submit">저장</button>
                <a class="btn btn-secondary" href="/guestbook">돌아가기</a>
            </div>
        </form>
    </div>
</div>
</body>
</html>
