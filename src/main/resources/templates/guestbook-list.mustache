<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>목록</title>
</head>
<body>

<h2>방명록 목록</h2>

<a href="/guestbook/write">글 작성</a>

{{#list}}
<div>
    <p>작성자: {{author}}</p>
    <p>내용: {{content}}</p>
    <p>작성일: {{createdAt}}</p>

    <form action="/guestbook/{{id}}/delete" method="post">
        <button type="submit">삭제</button>
    </form>
</div>
<hr>
{{/list}}

</body>
</html>